{
  "name": "sparc-android-dev",
  "version": "0.1.0",
  "description": "SPARC Edge Orchestrator for Android Development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run test",
    "docs": "typedoc --out docs src"
  },
  "keywords": [
    "supabase",
    "edge-functions",
    "android",
    "mobile",
    "orchestration",
    "workflow",
    "state-management"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/sparc-android-dev.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/sparc-android-dev/issues"
  },
  "homepage": "https://github.com/yourusername/sparc-android-dev#readme",
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.11",
    "@types/uuid": "^9.0.1",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "eslint": "^8.38.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.24.4",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}